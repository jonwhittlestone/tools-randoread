# Copy to .env and fill in values. Never commit .env to git.

# Server port
PORT=8085

# Shared auth token (deep-link login) + when it was issued (RFC3339).
# The token is valid for 90 days from AUTH_TOKEN_ISSUED_AT. Generate a new
# token and bump the issued-at date to rotate/renew.
AUTH_TOKEN=change-me-to-a-strong-random-string
AUTH_TOKEN_ISSUED_AT=2026-01-01T00:00:00Z

# Dropbox app key (public — shared with tools-browsernotes' app registration)
DROPBOX_APP_KEY=
DROPBOX_REDIRECT_URI=https://howapped.zapto.org/randoread/api/dropbox/callback

# Where the Dropbox token file (and other local state) is persisted. Defaults
# to "data" (relative to the working dir) if unset — matches the volume
# mounted at /app/data in docker-compose.yml / deploy.sh.
DATA_DIR=data

# randoread's externally visible URL (with path prefix) — used to build
# absolute image URLs in emails, since an email client has no <base> tag.
# Defaults to https://howapped.zapto.org/randoread/ if unset.
PUBLIC_BASE_URL=https://howapped.zapto.org/randoread/

# Email (used to send a rendered note as an HTML email). EMAIL_USER/PASS are
# a Gmail app password, same account as tools-browsernotes. EMAIL_FROM
# defaults to EMAIL_USER; EMAIL_TO defaults to jon@howapped.com.
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=
EMAIL_TO=jon@howapped.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
